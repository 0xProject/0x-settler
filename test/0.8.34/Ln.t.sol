pragma solidity ^0.8.34;

import {Ln} from "src/vendor/Ln.sol";
import {Test} from "@forge-std/Test.sol";

contract LnTest is Test {
    error LnWadUndefined();

    int256 private constant _MIN_RESULT = -41446531673892822313; // lnWad(1)
    int256 private constant _MAX_RESULT = 135305999368893231588; // lnWad(2**255 - 1)
    // floor(ln(2) * 10**18); the exact value's fractional part is ~0.417
    int256 private constant _LN2_WAD_FLOOR = 693147180559945309;

    function _lnWad(int256 x) internal virtual returns (int256) {
        return Ln.lnWad(x);
    }

    /// Asserts that `lnWad(x)` returns exactly `expected`, and that `expected` honors the
    /// specification `r == floor(L) || r == floor(L) - 1` for the independently computed
    /// `floorL = floor(10**18 * ln(x / 10**18))`. Reference values were generated with
    /// 1500-bit precision arithmetic.
    function _check(int256 x, int256 floorL, int256 expected) internal {
        assertTrue(expected == floorL || expected == floorL - 1, "vector violates spec");
        assertEq(_lnWad(x), expected, "lnWad mismatch");
    }

    function testLnWadVectors() external {
        _check(1, -41446531673892822313, -41446531673892822313);
        _check(2, -40753384493332877003, -40753384493332877003);
        _check(3, -40347919385224712621, -40347919385224712622);
        _check(10, -39143946580898776629, -39143946580898776629);
        _check(1000000000, -20723265836946411157, -20723265836946411157);
        _check(999999999999999999, -2, -2);
        _check(1000000000000000000, 0, -1);
        _check(1000000000000000001, 0, 0);
        _check(1000000000000000002, 1, 1);
        _check(2000000000000000000, 693147180559945309, 693147180559945309);
        _check(3000000000000000000, 1098612288668109691, 1098612288668109691);
        _check(2718281828459045235, 999999999999999999, 999999999999999999);
        _check(2718281828459045236, 1000000000000000000, 1000000000000000000);
        _check(1000000000000000000000000000, 20723265836946411156, 20723265836946411156);
        _check(1000000000000000000000000000000000000, 41446531673892822312, 41446531673892822312);
        _check(123456789123456789123456789, 18631401767168018033, 18631401767168018033);
        _check(79228162514264337593543950335, 25095597659861927391, 25095597659861927391);
        _check(79228162514264337593543950336, 25095597659861927391, 25095597659861927391);
        _check(79228162514264337593543950337, 25095597659861927391, 25095597659861927391);
        _check(158456325028528675187087900672, 25788744840421872701, 25788744840421872701);
        _check(112045541949572279837463876455, 25442171250141900046, 25442171250141900046);
        _check(112045541949572279837463876454, 25442171250141900046, 25442171250141900046);
        _check(112045541949572279837463876456, 25442171250141900046, 25442171250141900046);
        _check(114734634956362014553563009489920, 32373643055741353140, 32373643055741353140);
        _check(258359429617980926666593621001919026511908700160, 67724149264298563920, 67724149264298563920);
        _check(
            40938685753732063808775600771520380172681727073150978889983997520666710507520,
            134959425778613258934,
            134959425778613258934
        );
        _check(
            57896044618658097711785492504343953926634992332820282019728792003956564819967,
            135305999368893231589,
            135305999368893231588
        );
        _check(
            28948022309329048855892746252171976963317496166410141009864396001978282422329,
            134612852188333286279,
            134612852188333286279
        );
        _check(56022770974786139918731938227, 24749024069581954737, 24749024069581954736);
        _check(23140692632779268995, 3141592653589793237, 3141592653589793237);
        _check(23140692632779268996, 3141592653589793238, 3141592653589793237);
        _check(969072426304810639, -31415926535897933, -31415926535897933);
        _check(969072426304810640, -31415926535897932, -31415926535897932);
        _check(2493075895410188562, 913517247483640898, 913517247483640898);
        _check(2493075895410188563, 913517247483640899, 913517247483640898);
        _check(
            57896044618658097591920718310284239161260751360541374280977511124995241430418,
            135305999368893231586,
            135305999368893231586
        );
        _check(
            57896044618658097591920718310284239161260751360541374280977511124995241430419,
            135305999368893231587,
            135305999368893231586
        );
        _check(
            11531340134437266330889532247840319230885847573287662864764254025110034622679,
            133692418858407420767,
            133692418858407420767
        );
        _check(
            25516211913201189358184556770476725351838266340863452733436591784686693881804,
            134486664312116391125,
            134486664312116391125
        );
        _check(
            12632054297359577276854956051144103779902310235702452798294750994440826097481,
            133783587876002393482,
            133783587876002393482
        );
        _check(
            19773015028832046656908425566003276233326493345842583107020653497704963467163,
            134231668431467386104,
            134231668431467386104
        );
        _check(
            26369303708180783249380978459038522241083721636123224543466395688722460378193,
            134519550895981731608,
            134519550895981731608
        );
        _check(
            7929557224029897922379974571763889658076579711267156775272714680526020418224,
            133317947499191107922,
            133317947499191107922
        );
        _check(
            806542931244966051059409939570788318127957726580128171790838039545703343801,
            131032352149376846726,
            131032352149376846726
        );
        _check(
            13625595200484246010113629581784085527247382575443943192068219507274893064444,
            133859300324694985150,
            133859300324694985150
        );
    }

    function lnWadExternal(int256 x) external returns (int256) {
        return _lnWad(x);
    }

    function testLnWadUndefined() external {
        vm.expectRevert(LnWadUndefined.selector);
        this.lnWadExternal(0);
        vm.expectRevert(LnWadUndefined.selector);
        this.lnWadExternal(-1);
        vm.expectRevert(LnWadUndefined.selector);
        this.lnWadExternal(type(int256).min);
    }

    /// `L(2x) - L(x) = 10**18 * ln(2)` exactly. Both results lie in `(L - 2, L]`, so their
    /// difference lies in `(10**18 * ln(2) - 2, 10**18 * ln(2) + 2)`; with the fractional part
    /// of `10**18 * ln(2)` being ~0.417, the difference of the integer results is confined to
    /// `[floor - 1, floor + 2]`.
    function testFuzzLnWadDouble(int256 x) external {
        x = bound(x, 1, (type(int256).max >> 1));
        int256 d = _lnWad(x << 1) - _lnWad(x);
        assertGe(d, _LN2_WAD_FLOOR - 1, "doubling delta too low");
        assertLe(d, _LN2_WAD_FLOOR + 2, "doubling delta too high");
    }

    function testFuzzLnWadRange(int256 x) external {
        x = bound(x, 1, type(int256).max);
        int256 r = _lnWad(x);
        assertGe(r, _MIN_RESULT, "below global minimum");
        assertLe(r, _MAX_RESULT, "above global maximum");
    }
}
